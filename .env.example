# --- Next.js (apps/web) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- FastAPI (apps/api) — copy to apps/api/.env for local uvicorn ---
ENV=development
DATABASE_URL=postgresql://postgres:your-db-password@db.your-project-ref.supabase.co:5432/postgres?sslmode=require
DATABASE_POOL_MIN=1
DATABASE_POOL_MAX=10
DATABASE_POOL_TIMEOUT_SECONDS=10
DATABASE_COMMAND_TIMEOUT_SECONDS=30
SUPABASE_PROJECT_URL=https://your-project-ref.supabase.co
SUPABASE_JWT_VERIFY_MODE=jwks
SUPABASE_JWKS_URL=https://your-project-ref.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWT_ISSUER=https://your-project-ref.supabase.co/auth/v1
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_JWT_SECRET=
CORS_ORIGINS=http://localhost:3000

# Optional: Plaid (future ingestion)
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# Optional: Redis
REDIS_URL=redis://localhost:6379/0
